# OneTap Atelier — environment.
#
# Generation is plug-and-play and PURELY env-driven:
#   <MODALITY>_PROVIDER  picks the provider (default: mock)
#   <MODALITY>_MODEL     picks the model for that provider
#
# Default (nothing set) = mock providers, so `npm run dev` works with ZERO config.
# If you select a real provider but omit its keys, the request FAILS LOUD with a
# clear error (it does NOT silently fall back to mock).
#
# Check what's live at:  GET /api/ai-status  (dev only)

# A "try-on" = compose the garment onto the user's photo (Kling Virtual Try-On,
# image+image -> image), then animate that image into a 360°/film (Grok
# image-to-video). Pipeline: generate-image (Kling) -> generate-360/video (Grok).

# --- Try-On image (image + image -> image) ---------------------------------
# TRYON_PROVIDER=kling                       # registered: mock | kling | grok | gpt-image | gemini
# TRYON_MODEL=kolors-virtual-try-on-v1-5     # Kling try-on model
KLING_ACCESS_KEY=              # required when TRYON_PROVIDER=kling
KLING_SECRET_KEY=             # required when TRYON_PROVIDER=kling
# KLING_BASE_URL=https://api.klingai.com     # optional endpoint override

# GPT-Image scene composition (person + garment + PROMPT -> scene image).
# Prompt-capable, unlike Kling try-on. Used for the FIFA moment image prompt.
# Set TRYON_PROVIDER=gpt-image to switch. Requires a verified OpenAI org.
# OPENAI_API_KEY=sk-...        # required when TRYON_PROVIDER=gpt-image
# OPENAI_IMAGE_MODEL=gpt-image-2     # or a dated snapshot
# OPENAI_IMAGE_SIZE=864x1536         # default 9:16 — MUST match VIDEO_ASPECT or the
#                                    # image-to-video step stretches the subject.
#                                    # WxH both ÷16, aspect 1:3–3:1 (1024x1536 = 2:3).
# OPENAI_IMAGE_QUALITY=auto          # low | medium | high | auto

# Gemini ("Nano Banana") scene composition — lower latency than GPT-Image.
# Set TRYON_PROVIDER=gemini to switch. Toggle the two models to compare.
# GEMINI_API_KEY=...           # required when TRYON_PROVIDER=gemini
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image   # fast; or gemini-3-pro-image (quality)
# GEMINI_IMAGE_ASPECT=9:16     # default 9:16 — keep matching VIDEO_ASPECT. Some
# GEMINI_IMAGE_SIZE=2K         # v1beta deployments reject these — if so the provider
#                              # auto-retries WITHOUT them (model uses its default).
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta   # optional override

# --- 360 Spin + Film (image -> video) --------------------------------------
# VIDEO_PROVIDER=grok                        # registered: mock | grok | kling
# VIDEO_MODEL=grok-imagine-video             # xAI image-to-video model
XAI_API_KEY=xai-...           # required when VIDEO_PROVIDER=grok (also TRYON=grok / IDENTITY=grok)
# Optional video output tuning (defaults: 9:16, 720p, 5s):
# VIDEO_ASPECT=9:16
# VIDEO_RESOLUTION=720p        # 480p | 720p — 720p keeps faces sharp (recommended)
# VIDEO_DURATION=5             # seconds, 1–15

# --- Product image capture (admin re-host) ---------------------------------
# Fallback proxy used when a retailer CDN blocks our direct fetch (e.g. Versace
# demandware 403s our IP). {url} is replaced with the URL-encoded source.
# Default is the free images.weserv.nl; swap for a paid scraping API for hard cases.
# IMAGE_PROXY_TEMPLATE=https://images.weserv.nl/?url={url}

# --- Identity model sheet (photos -> one multi-angle composite) ------------
# IDENTITY_PROVIDER=grok       # registered: mock | grok   (default: mock)
# IDENTITY_MODEL=grok-2-image  # xAI image model; uses XAI_API_KEY above.

# Print sanitized AI request bodies (prompts + params) to the server terminal.
# On by default; set to 0 to silence.
# AI_DEBUG=1

# --- Catalog persistence (Supabase) ----------------------------------------
# Without these the app runs on the mock catalog (lib/data/products.ts).
# Set all three to persist admin-added products and serve them in the grid.
# The service-role key also re-hosts generated looks into the public `looks`
# Storage bucket (durable, shareable /look/[id] links); profile photos stay in
# the private `avatars` bucket. Run lib/supabase/schema.sql first (creates both).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin (product import) ------------------------------------------------
# Shared password gating /admin and the admin write endpoints. Required to
# add products via URL. Keep it secret — it is checked server-side only.
ADMIN_PASSWORD=

# --- FIFA "Try-on in Action" rail ------------------------------------------
# Comma-separated PUBLIC video URLs (e.g. Supabase Storage) for the auto-
# scrolling reel rail on /fifa. NEXT_PUBLIC_ because it renders client-side;
# inlined at build time, so changing it needs a rebuild/redeploy. Empty = rail
# hidden. NEXT_PUBLIC_FIFA_SHOWCASE_URLS=https://…/a.mp4,https://…/b.mp4
NEXT_PUBLIC_FIFA_SHOWCASE_URLS=

# --- Meta (Facebook) Pixel -------------------------------------------------
# Loaded on every page (PageView + route-change PageViews). Public client-side
# id. Falls back to the built-in id if unset; override here per environment.
# NEXT_PUBLIC_META_PIXEL_ID=2075924653360905

# --- Google Analytics (GA4) / Tag Manager / SEO ----------------------------
# Loaded on every page (gtag + GTM, with SPA route-change pageviews). Public,
# client-side ids. Both fall back to the configured defaults if unset; clear an
# id to disable that tag. CAVEAT: GA4 loads BOTH directly (gtag) AND via GTM — if
# your GTM container also has a GA4 config tag for the same property, pageviews
# double-count. Clear NEXT_PUBLIC_GA_ID to let GTM own GA4, or leave GTM empty
# for gtag only.
# NEXT_PUBLIC_GTM_ID=GTM-PC7PQBSJ
# NEXT_PUBLIC_GA_ID=G-ENEMM2LD0B
# Optional Google Search Console verification (renders the <meta> only when set;
# GSC can also verify via the GA/GTM tags above). NEXT_PUBLIC_SITE_URL (below)
# drives the sitemap, robots and Open Graph URLs — set it per environment.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Analytics (Mixpanel) --------------------------------------------------
# Product analytics for user interactions + purchase funnel. Without it the
# app runs fine and all track() calls no-op. Get the token from your Mixpanel
# project settings (Project Token). Public by design (client-side SDK).
NEXT_PUBLIC_MIXPANEL_TOKEN=

# --- Auth & Billing (real accounts + subscriptions) ------------------------
# Public site URL — used for OAuth redirects. http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Razorpay subscriptions (international / USD). Without these, billing is disabled
# and the app still runs (mock providers, free-trial limit only).
# Plan PRICES/LIMITS/features are admin-editable in the DB (billing_plans, seeded
# from lib/pricing/plans.ts). NOTE: a subscription's REAL charge is fixed by its
# Razorpay plan below — the admin "price" field is display-only, so keep them in
# sync. Top-ups use one-time Razorpay ORDERS (amount computed from the admin
# top-up unit price), so no extra plan/env is needed for them.
# The webhook must also send payment.captured (for top-ups), not only subscription.*.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_FAN=          # FIFA "Viral Fan" membership ($25/mo) — campaign only
