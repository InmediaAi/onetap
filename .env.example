# OneTap Atelier — environment.
# The app runs with ZERO config (mock providers). Add keys below to enable
# live generation; each block is independent.

# --- Photo Try-On (xAI / Grok image) ---------------------------------------
# Set to switch Photo Try-On from mock to live Grok generation.
XAI_API_KEY=
# Optional overrides:
# XAI_IMAGE_MODEL=grok-2-image
# TRYON_PROVIDER=grok        # force a provider; defaults to grok if key present, else mock

# --- 360 Spin + Social Video (Kling image->video) --------------------------
# Both keys required to enable live Kling video generation.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# Optional overrides:
# KLING_BASE_URL=https://api.klingai.com
# KLING_MODEL=kling-v1
# VIDEO_PROVIDER=kling       # force a provider; defaults to kling if keys present, else mock

# --- Future (scaffolded, not wired in MVP) ---------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
